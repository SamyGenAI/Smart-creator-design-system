BRANDFETCH_API_KEY=
LOGO_DEV_API_KEY=
FIRECRAWL_API_KEY=

# Figma MCP — optional, only needed if you want to push designs to Figma
# FIGMA_FILE_KEY is the alphanumeric ID in your Figma file URL:
#   figma.com/design/<FIGMA_FILE_KEY>/...
# FIGMA_CAROUSEL_NODE_ID and FIGMA_INFOGRAPHIC_NODE_ID are the target page/frame node IDs
#   (right-click a page or frame in Figma → "Copy link" → extract the node-id param)
FIGMA_FILE_KEY=
FIGMA_CAROUSEL_NODE_ID=
FIGMA_INFOGRAPHIC_NODE_ID=
